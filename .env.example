# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (RBAC, users, roles, audit)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rbac_db
DB_USER=postgres
DB_PASSWORD=your_password

# MSSQL (EOAF metadata)
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=dm_General_docbase
MSSQL_USER=sa
MSSQL_PASSWORD=your_password
MSSQL_ENCRYPT=false
MSSQL_TRUST_CERT=true

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12
